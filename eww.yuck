(include "./variables.yuck")
(include "./modules/media-player.yuck")
(include "./modules/bar.yuck")
(include "./modules/audio-control.yuck")
(include "./modules/bluetooth-control.yuck")
(include "./modules/network-control.yuck")
(include "./modules/system-control.yuck")


(defwindow media-player_Window
           :monitor 0
           :geometry (geometry :x "1%"
                               :y "1%"
                               :width "20%"
                               :height "20%"
                               :anchor "top right")
           :stacking "fg"
           :windowtype "normal"
           :wm-ignore true
           (media-player_mainWidget))

(defwindow bar_Window
           :monitor 0
           :geometry (geometry :x "0%"
                               :y "1%"
                               :width "98%"
                               :height "3%"
                               :anchor "top center")
           :stacking "fg"
           :windowtype "dock"
           :exclusive true
           :focusable false
           :wm-ignore false
           (bar_mainWidget))

(defwindow audio-control_Window
          :monitor 0
          :geometry (geometry :x "1%"
                              :y "1%"
                              :width "20%"
                              :height "15%"
                              :anchor "top right")
          :stacking "fg"
          :wm-ignore true
          :windowtype "normal"
          (audio-control_mainWidget))

(defwindow network-control_Window
          :monitor 0
          :geometry (geometry :x "0%"
                              :y "0%"
                              :width "25%"
                              :height "20%"
                              :anchor "top right")
          :stacking "fg"
          :wm-ignore true
          :windowtype "normal"
          (network-control_mainWidget))

(defwindow bluetooth-control_Window
          :monitor 0
          :geometry (geometry :x "1%"
                              :y "1%"
                              :width "25%"
                              :height "20%"
                              :anchor "top right")
          :stacking "fg"
          :wm-ignore true
          :windowtype "normal"
          (bluetooth-control_mainWidget))

(defwindow network-control_Window
          :monitor 0
          :geometry (geometry :x "1%"
                              :y "1%"
                              :width "25%"
                              :height "18%"
                              :anchor "top right")
          :stacking "fg"
          :wm-ignore true
          :windowtype "normal"
          :focusable true
          (network-control_mainWidget))
(defwindow system-control_Window
          :monitor 0
          :geometry (geometry :y "1%"
                              :width "15%"
                              :height "6%"
                              :anchor "top center")
          :stacking "fg"
          :wm-ignore true
          :windowtype "normal"
          (system-control_mainWidget))
